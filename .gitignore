# Build trees
build/
build-*/

# Packaged distributions
dist-*/
dist-*.zip

# Cross-build dependency cache (recreated by scripts/build-win64-deps.sh)
win64-deps/

# Runtime state
imgui.ini
*.log

# Per-user runtime data — NEVER commit: these hold real people's face
# embeddings (biometric data) and the operator's stream targets. Created at
# runtime; the packagers ship an empty profiles/ folder.
gallery/
profiles/

# EvoControl runtime state — NEVER commit: the SQLite DB holds the gift ledger,
# accounts, and performer face embeddings (biometric data); avatars/ and faces/
# cache real people's pictures; widgets/ is the installed-bundle registry;
# reports/ are exported shift reports. All are created at runtime.
evocontrol.db
evocontrol.db-shm
evocontrol.db-wal
avatars/
faces/
reports/
/widgets/

# Voxtral speech-to-text GGUF weights (~2.7 GB) — too large for git; fetch
# with third_party/voxtral/tools/download_model.sh into models/voxtral/.
models/voxtral/
*.gguf

# Local build/ops notes (not for the public repo).
WINDOWS-NATIVE-BUILD-OVER-SSH.md
